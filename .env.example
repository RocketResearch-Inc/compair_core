COMPAIR_EDITION=core

# Run in local single-user mode while developing
COMPAIR_REQUIRE_AUTHENTICATION=false
COMPAIR_REQUIRE_EMAIL_VERIFICATION=false

# SQLite-first local setup
COMPAIR_DB_DIR=.compair-data
COMPAIR_DB_NAME=compair.db

# Local defaults
COMPAIR_EMBEDDING_PROVIDER=local
COMPAIR_GENERATION_PROVIDER=local
COMPAIR_LOCAL_MODEL_URL=http://127.0.0.1:9000

# Optional if using OpenAI instead of local generation/embeddings
COMPAIR_OPENAI_API_KEY=
COMPAIR_OPENAI_MODEL=gpt-5-nano

# Optional OCR service
COMPAIR_OCR_ENDPOINT=http://127.0.0.1:9001/ocr-file
COMPAIR_OCR_REQUEST_TIMEOUT=30